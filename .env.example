# Copy to .env (project root) and fill in. CRA requires the REACT_APP_ prefix
# and a rebuild for changes to take effect. Set the same var in
# Amplify → App settings → Environment variables for deploys.
#
# This ID is NOT a secret — it ships in the client bundle by design.

# Meta Pixel ID (required for ad-conversion tracking & retargeting)
REACT_APP_META_PIXEL_ID=XXXXXXXXXXXXXXX
